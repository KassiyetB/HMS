# ── Server ────────────────────────────────────────
PORT=5000

# ── PostgreSQL ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── CORS ──────────────────────────────────────────
# Your React frontend URL
CLIENT_URL=http://localhost:5173

# ── Auth ──────────────────────────────────────────
# Кемінде 32 таңбалы кездейсоқ жол
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=8h
